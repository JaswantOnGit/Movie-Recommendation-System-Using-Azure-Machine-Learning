# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file.

# -------------------------------------------------------
# Azure Subscription & Workspace
# -------------------------------------------------------
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_ML_WORKSPACE_NAME=your-aml-workspace-name

# -------------------------------------------------------
# Azure Blob Storage
# -------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=movie-data

# -------------------------------------------------------
# Azure Cosmos DB
# -------------------------------------------------------
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=recommendations
COSMOS_CONTAINER=user-recommendations

# -------------------------------------------------------
# Deployed Model Endpoint (ACI / AKS)
# -------------------------------------------------------
# Set AFTER deploying the model via Azure ML
AML_ENDPOINT_URL=https://your-endpoint.inference.ml.azure.com/score
AML_ENDPOINT_KEY=your-endpoint-api-key

# -------------------------------------------------------
# Local inference server
# -------------------------------------------------------
MODEL_PATH=models/svd_model.pkl
DATA_PATH=data/processed/cleaned_ratings.csv
PORT=5000
